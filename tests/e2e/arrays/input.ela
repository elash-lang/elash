int sumArray(int[3] arr) {
    int sum = 0;
    int i = 0;
    while (i < 3) {
        sum += arr[i++];
    }
    return sum;
}

int main() {
    int[3] arr;
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    
    if (len(arr) != 3) return 1;
    if (sumArray(arr) != 60) return 2;

    return 0;
}

