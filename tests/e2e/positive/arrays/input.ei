int sumArray(int[3] arr) {
    int sum = 0;
    usize i = 0;
    while (i < 3) {
        sum += arr[i++];
    }
    return sum;
}

int main() {
    int[3] arr = { 10, 20, 30 };

    if (len(arr) != 3) return 1;
    if (sumArray(arr) != 60) return 2;

    arr = int[3] { 1, 2, 3 };
    if (sumArray(arr) != 6) return 3;

    int[3] arr2 = int[3] { 4, 9, 2 };
    arr = arr2;

    if (sumArray(arr) != sumArray(arr2)) {
        return 4;
    }

    int n = int[5] { 0, 1, 2, 3, 4 } [2];
    if (n != 2) return 5;

    if (sumArray({ 10, 20, 30 }) != sumArray(int[3] { 10, 20, 30 })) {
        return 6;
    }

    int[2][2] matrix = {
        { 1, 2 },
        { 3, 4 },
    };

    if (matrix[0][0] != 1 || matrix[1][0] != 3 || matrix[1][1] != 4) {
        return 7;
    }

    matrix[1] = int[2] { 10, 20 };
    if (matrix[0][0] != 1 || matrix[1][0] != 10 || matrix[1][1] != 20) {
        return 8;
    }

    return 0;
}

