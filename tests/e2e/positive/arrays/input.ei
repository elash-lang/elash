int sumArray(int[3] arr) {
    int sum = 0;
    usize i = 0;
    while (i < 3) {
        sum += arr[i++];
    }
    return sum;
}

int main() {
    int[3] arr = { 10, 20, 30 };

    if (len(arr) != 3) return 1;
    if (sumArray(arr) != 60) return 2;

    arr = int[3] { 1, 2, 3 };
    if (sumArray(arr) != 6) return 3;

    int[3] arr2 = int[3] { 4, 9, 2 };
    arr = arr2;

    if (sumArray(arr) != sumArray(arr2)) {
        return 4;
    }
    return 0;
}

